@inproceedings{wu_RowColumn_2018,
  title = {A {{Row-Column Arraya}} for {{Ultrasound-Based Tissue Anisotropy Measurement}}},
  booktitle = {2018 {{IEEE International Ultrasonics Symposium}} ({{IUS}})},
  author = {Wu, Huaiyu and Kim, Jinwook and Jiang, Xiaoning and Hossain, Md Murad and Gallippi, Caterina M.},
  date = {2018-10},
  pages = {1--4},
  issn = {1948-5727},
  doi = {10.1109/ULTSYM.2018.8580096},
  abstract = {Degree of anisotropy (DoA) in mechanical properties is a rapidly emerging biomarker for tissue pathology that has shown to be correlated to fatty infiltration in dystrophic skeletal muscle. DoA can be assessed either using ratio of shear wave velocities (SWV) or using acoustic radio forced impulse (ARFI)-induced peak displacements (PD) measured along versus across the muscle fibers. Whether using SWV or PD as a basis, DoA expressed as the ratio of values requires 90°transducer rotation when a linear array is employed. This large rotation angle is prone to misalignment error. Though fully sampled matrix arrays could enable electronic aperture rotation and reduce misalignment errors, their high fabrication cost and complicated fabrication procedures are challenges. To solve these problems, a custom row-column array is proposed in this paper. The row-column array contains 3x64 elements. The orthogonal pushing beam can be realized by x group pushing beam in which 5 rows on lateral-direction are fired together and the y-pushing beam in which center column in elevational-direction are fired. A custom designed flex circuit was applied to fabricate the array with simpler electrode connection than fully sampled matrix array. The performance of the array is evaluated in Field II simulation and experiment. The output pressure was 0.56 MPa output under a 40 Vpp excitation with similar beam-profile in orthogonal directions. With the capability of rotating the pushing beam electronically, the array has the potential for DoA assessment with reduce misalignment errors.},
  eventtitle = {2018 {{IEEE International Ultrasonics Symposium}} ({{IUS}})},
  keywords = {anisotropy,ARFI,Electronic rotation of the pushing beams,Orthogonal pushing beams,Row-column array},
  file = {/Users/keita/Library/CloudStorage/OneDrive-Personal/Documents/Zotero/2018-Wu et al-A Row-Column Arraya for Ultrasound-Based Tissue Anisotropy Measurement.pdf;/Users/keita/Library/CloudStorage/OneDrive-Personal/Documents/Zotero/W/WuH/2018__WuH_GallippiC__A Row-Column Arraya for Ultrasound-Based Tissue Anisotropy Measurement2.pdf}
}

@article{wu_Utility_2023,
  title = {Utility of Shear Wave–Based Ultrasound Elastography in Chronic Kidney Disease and Related Pathological Quantitative Analysis},
  author = {Wu, Jingping and Li, Guanghan and Liu, Jian and Sun, Weiliang and Liu, Jiang and Zou, Guming and Lu, Haitao and Zheng, Min},
  date = {2023-08},
  journaltitle = {European Radiology},
  volume = {33},
  number = {8},
  pages = {5625--5633},
  publisher = {Springer Nature B.V.},
  location = {Heidelberg, Netherlands},
  issn = {09387994},
  doi = {10.1007/s00330-023-09507-1},
  abstract = {Objectives The purpose of this study was to investigate the effects of tissue fibrosis and microvessel density on shear wave–based ultrasound elastography (SWUE) of chronic kidney disease (CKD). In addition, we were looking to see whether SWUE could predict stage of CKD, correlating with the histology on kidney biopsy. Methods Renal tissue sections from 54 patients diagnosed with suspected CKD were subjected to immunohistochemistry (CD31 and CD34), and the degree of tissue fibrosis was assessed using Masson staining. Before renal puncture, both kidneys were examined using SWUE. Comparative analysis was used to assess the correlation between SWUE and microvessel density, and between SWUE and the degree of fibrosis. Results Fibrosis area according to Masson staining (p {$<$} 0.05) and integrated optical density (IOD) (p {$<$} 0.05) were positively correlated with CKD stage. The percentage of positive area (PPA) and IOD for CD31 and CD34 were not correlated with CKD stage (p {$>$} 0.05). When stage 1 CKD was removed, PPA and IOD for CD34 were negatively correlated with CKD stage (p {$<$} 0.05). Masson staining fibrosis area and IOD were not correlated with SWUE (p {$>$} 0.05), PPA and IOD for CD31 and CD34 were not correlated with SWUE (p {$>$} 0.05) and, finally, no correlation between SWUE and CKD stage was found (p {$>$} 0.05). Conclusion The diagnostic value of SWUE for CKD staging was very low. The utility of SWUE in CKD was affected by many factors and its diagnostic value was limited. Key Points • There was no correlation between SWUE and the degree of fibrosis, or between SWUE and microvessel density among patients with CKD. • There was no correlation between SWUE and CKD stage and the diagnostic value of SWUE for CKD staging was very low. • The utility of SWUE in CKD is affected by many factors and its value was limited.},
  langid = {english},
  pagetotal = {5625-5633},
  keywords = {Biopsy,CD34 antigen,Chronic kidney disease,Comparative analysis,Diagnostic systems,Elasticity imaging techniques,Elastography,Fibrosis,Histology,Immunohistochemistry,Kidney diseases,Kidneys,Microvascular density,Optical density,Quantitative analysis,S wave,Staining,Tissues,Ultrasonic imaging,Ultrasonography,Ultrasound},
  file = {/Users/keita/Zotero/storage/EKK9B2NU/Wu et al. - 2023 - Utility of shear wave–based ultrasound elastography in chronic kidney disease and related pathologic.pdf}
}

