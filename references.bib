}

@article{irshad_review_2008,
  title = {A Review of Sonographic Evaluation of Renal Transplant Complications},
  author = {Irshad, Abid and Ackerman, Susan and Sosnouski, David and Anis, Munazza and Chavin, Kenneth and Baliga, Prabhaker},
  date = {2008},
  journaltitle = {Current Problems in Diagnostic Radiology},
