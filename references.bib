@article{lim_Shear_2021,
  title = {Shear {{Wave Elastography}}: {{A Review}} on the {{Confounding Factors}} and {{Their Potential Mitigation}} in {{Detecting Chronic Kidney Disease}}},
  shorttitle = {Shear {{Wave Elastography}}},
  author = {Lim, William T. H. and Ooi, Ean H. and Foo, Ji J. and Ng, Kwan H. and Wong, Jeannie H. D. and Leong, Sook S.},
  date = {2021-08-01},
  journaltitle = {Ultrasound in Medicine \& Biology},
  shortjournal = {Ultrasound in Medicine \& Biology},
  volume = {47},
  number = {8},
  pages = {2033--2047},
  issn = {0301-5629},
  doi = {10.1016/j.ultrasmedbio.2021.03.030},
  abstract = {Early detection of chronic kidney disease is important to prevent progression of irreversible kidney damage, reducing the need for renal transplantation. Shear wave elastography is ideal as a quantitative imaging modality to detect chronic kidney disease because of its non-invasive nature, low cost and portability, making it highly accessible. However, the complexity of the kidney architecture and its tissue properties give rise to various confounding factors that affect the reliability of shear wave elastography in detecting chronic kidney disease, thus limiting its application to clinical trials. The objective of this review is to highlight the confounding factors presented by the complex properties of the kidney, in addition to outlining potential mitigation strategies, along with the prospect of increasing the versatility and reliability of shear wave elastography in detecting chronic kidney disease.},
  keywords = {Acoustic radiation force,Anisotropy,Chronic kidney disease,Fibrosis,Hemodynamics,Medical imaging,Shear wave elastography,Stiffness,Ultrasound,Viscoelasticity},
  file = {/Users/keita/Zotero/storage/XUYWLQU5/Lim et al. - 2021 - Shear Wave Elastography A Review on the Confounding Factors and Their Potential Mitigation in Detec.pdf;/Users/keita/Zotero/storage/ZM2I8S45/S0301562921001514.html}
}

