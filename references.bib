}

@article{zhan_Acoustic_2015,
  title = {Acoustic Radiation Force Impulse Imaging ({{ARFI}}) for Differentiation of Benign and Malignant Thyroid Nodules—{{A}} Meta-Analysis},
  author = {Zhan, Jia and Jin, Jia-Mei and Diao, Xue-Hong and Chen, Yue},
