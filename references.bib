@article{szabo_Acoustic_2023,
  title = {Acoustic {{Radiation Forces}} at the {{Crossroads}} of {{Ultrasound Exposimetry}}, {{HIFU}}, and {{Elastography}}},
  author = {Szabo, Thomas L.},
  date = {2023-02},
