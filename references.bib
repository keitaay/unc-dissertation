@article{rifkin_Evaluation_1987,
  title = {Evaluation of Renal Transplant Rejection by Duplex {{Doppler}} Examination: Value of the Resistive Index},
  shorttitle = {Evaluation of Renal Transplant Rejection by Duplex {{Doppler}} Examination},
  author = {family=Rifkin, given=MD, given-i=MD and Needleman, L and family=Pasto, given=ME, given-i=ME and family=Kurtz, given=AB, given-i=AB and family=Foy, given=PM, given-i=PM and McGlynn, E and Canino, C and family=Baltarowich, given=OH, given-i=OH and family=Pennell, given=RG, given-i=RG and family=Goldberg, given=BB, given-i=BB},
