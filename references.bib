}

@article{ioannidis_Custom_2020,
  title = {A {{Custom Ultra-Low-Cost 3D Bioprinter Supports Cell Growth}} and {{Differentiation}}},
  author = {Ioannidis, Konstantinos and Danalatos, Rodolfos I. and Champeris Tsaniras, Spyridon and Kaplani, Konstantina and Lokka, Georgia and Kanellou, Anastasia and Papachristou, Dionysios J. and Bokias, Georgios and Lygerou, Zoi and Taraviras, Stavros},
