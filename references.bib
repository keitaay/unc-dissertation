  shorttitle = {Imaging Fibrosis in Pediatric Kidney Transplantation},
  author = {Elsingergy, Mohamed M. and Viteri, Bernarda and Otero, Hansel J. and Bhatti, Tricia and Morales, Tatiana and Roberts, Timothy P. L. and Amaral, Sandra and Hartung, Erum and Serai, Suraj D.},
