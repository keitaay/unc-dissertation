@article{gao_Ultrasound_2020,
  title = {Ultrasound {{Shear Wave Elastography}} and {{Doppler Sonography}} to {{Assess}} the {{Effect}} of {{Hydration}} on {{Human Kidneys}}: {{A Preliminary Observation}}},
  shorttitle = {Ultrasound {{Shear Wave Elastography}} and {{Doppler Sonography}} to {{Assess}} the {{Effect}} of {{Hydration}} on {{Human Kidneys}}},
