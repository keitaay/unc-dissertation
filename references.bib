@online{yokoyama_DoubleProfile_2025,
  title = {Double-{{Profile Intersection}} ({{DoPIo}}) {{Ultrasound}}: {{Pointwise Shear Elasticity Estimation}} Using {{Paired Confocal Displacement Profiles}}},
  author = {Yokoyama, Keita A. and Hossain, Md. Murad and Muhtadi, Sabiq and Gallippi, Caterina M.},
  date = {2025-11-22},
  number = {2511.16878},
  eprint = {2511.16878},
  eprinttype = {arXiv},
  doi = {10.48550/arXiv.2511.16878},
  abstract = {Current acoustic radiation force (ARF) based methods for quantifying tissue elasticity primarily rely on shear wave propagation. However, their spatial resolution is limited by the need for spatial averaging, and their accuracy is affected by shear wave guidance, out of plane reflections, and geometric dispersion, which reduce their applicability in mechanically complex tissues. This study introduces a novel technique called Double Profile Intersection (DoPIo) ultrasound, which enables pointwise estimation of shear elastic modulus within the region of ARF excitation by leveraging the scatterer shearing rate. This rate is inferred by tracking ARF induced displacement using two tracking beams with different lateral widths. The wider beam captures scatterers located outside the ARF excitation region that begin to displace as shearing propagates. The time at which the two resulting displacement profiles intersect is mapped to shear elastic modulus using an empirically derived model based on finite element simulations. In silico, DoPIo estimated shear elastic modulus with a median error of -0.02 kPa and a median absolute deviation of 1.98 kPa in elastic materials up to 35 kPa. Experimental validation in vitro and ex vivo demonstrated that DoPIo reliably distinguished softer regions from stiffer ones, and its modulus estimates remained consistent across varying ARF push amplitudes, provided sufficient displacement estimation signal to noise ratio. DoPIo offers a feasible approach for high resolution, on axis shear elasticity estimation and holds promise as a quantitative biomarker that is independent of ARF amplitude.},
  pubstate = {prepublished}
}

@article{yokoyama_DoubleProfile_2025a,
  title = {Double-{{Profile Intersection Ultrasound Noninvasively Discriminates Porcine Renal Parenchyma}} with {{Inflammation}} and/or {{Fibrosis}}},
  author = {Yokoyama, Keita A and Muhtadi, Sabiq and Caughey, Melissa C and Nichols, Timothy C and Merricks, Elizabeth P and Sellers, Rani S and De La Cruz, Gabriela and Gallippi, Caterina M},
  date = {2025},
  journaltitle = {IEEE Open Journal of Ultrasonics, Ferroelectrics, and Frequency Control},
  volume = {In Review},
  abstract = {Double-profile intersection (DoPIo) ultrasound, an on-axis, acoustic radiation force-based imaging technique that was recently introduced to quantify the elasticity of soft, heterogeneously isotropic materials, was implemented in an in vivo pig model of renal ischemia-reperfusion injury (IRI). The IRIs were implemented to induce parenchymal inflammation acutely, fibrosis chronically, and both inflammation and fibrosis to simulate injuries observed in antibody-mediated rejections (AMR). These three injury cohorts, and a fourth uninjured control cohort, underwent renal DoPIo imaging, and DoPIo elasticity measures were compared against the performance of Viscoelastic Response (VisR) elastography for the same task. DoPIo shear elasticity estimates in the renal cortex and medulla, similarly to VisR, were significantly different between all three subtypes of injured kidneys versus those of uninjured kidneys. Binary classifiers to detect pathologies using VisR or DoPIo-derived inputs were developed using logistic regression, and the performance of each classifier was assessed using the area under the receiver operating characteristic curve (AUC). We found that a binary classifier based on DoPIo measurements showed improved performance over VisR in detecting injured kidneys (0.62 ± 0.10 VisR, 0.83 ± 0.05 DoPIo) and kidneys with a combination of acute and chronic IRI (0.54 ± 0.17 VisR v. 0.85 ± 0.03 DoPIo). These results suggest that DoPIo may be a noninvasive surveillance tool for potential AMR, while VisR may be preferred for specifically identifying parenchymal fibrosis.},
  langid = {english},
  file = {/Users/keita/Zotero/storage/Z75RY745/Yokoyama et al. - Double-Profile Intersection Ultrasound Noninvasively Discriminates Porcine Renal Parenchyma with Inf.pdf}
}

@inproceedings{yokoyama_Quantitative_2022,
