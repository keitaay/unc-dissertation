  keywords = {Acoustical properties,Bioacoustical properties,Biological effects of acoustic and ultrasonic energy,Biomedical imaging,Gels,Graphite,Materials properties,Medical diagnosis with acoustics,Medical imaging,Non-ionizing radiation equipment and techniques,Powders,Speed of sound,Tissues,Ultrasonic attenuation,Ultrasonics},
