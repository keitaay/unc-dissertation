@article{navarro_RUSEM_2019,
  title = {{{RUSEM}}: {{A}} Numerical Model for Policymaking and Climate Applications},
  shorttitle = {{{RUSEM}}},
  author = {Navarro, Andres and Tapiador, Francisco J.},
  date = {2019-11-01},
  journaltitle = {Ecological Economics},
  shortjournal = {Ecological Economics},
  volume = {165},
  pages = {106403},
  issn = {0921-8009},
  doi = {10.1016/j.ecolecon.2019.106403},
  abstract = {Uncertainties and non-linearities between processes involved in rural dynamics pose a challenge to planners and policymakers. Numerical models minimize the risk of making an inappropriate decision and assist planners with making informed policy decisions. In this paper, we present a quantitative analysis of the social, economic and demographic dimensions of rural dynamics using a system dynamics approach. The resulting model (RUSEM: RUral Socio-Economic Model) consists of four main modules that reproduce the main characteristics of the rural areas, with a focus for the European case. The economic module contains the most important variables in the dynamics of local economies - for example, the provision of key services, the availability of public services, and local economic structure. The social and demographic modules use large age groups to analyse the labour market and population dynamics. The attractiveness module summarises push-pull factors affecting rural migration. The model is used to evaluate thirty-six socio-economic scenarios of rural Spain. The results show that very small villages could be incapable to stop rural decline because the absence of “critical mass” while mid-sized villages require targeted actions to reinforce the positive feedbacks of local economy. RUSEM has two goals: to offer computational support enabling robust decision-making in policy formulation in conditions of deep uncertainty and to integrate the socio-economic dimension into Earth System Models (ESMs) providing a numerical model that can be embedded into ESMs at a relatively cheap computational cost.},
  keywords = {Climate,Economy,Policy,Rural,Sustainability,System Dynamics},
  file = {/Users/keita/Zotero/storage/4YBQCSWW/Navarro and Tapiador - 2019 - RUSEM A numerical model for policymaking and clim.pdf;/Users/keita/Zotero/storage/HWTJ2VEU/S0921800918313776.html}
}

@article{nayana_cross_2017,
  title = {A Cross Sectional Study on Assessment of Health Related Quality of Life among End Stage Renal Disease Patients Undergoing Hemodialysis},
  author = {Nayana, S. A. and Balasubramanian, T. and Nathaliya, P. M. and Nimsha Hussain, P. and Mohammed Salim, K. T. and Muhammed Lubab, P.},
