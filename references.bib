@article{balleyguier_Breast_2013,
  title = {Breast Elastography: {{The}} Technical Process and Its Applications},
  shorttitle = {Breast Elastography},
  author = {Balleyguier, C. and Ciolovan, L. and Ammari, S. and Canale, S. and Sethom, S. and Al Rouhbane, R. and Vielh, P. and Dromain, C.},
  date = {2013-05-01},
  journaltitle = {Diagnostic and Interventional Imaging},
  shortjournal = {Diagnostic and Interventional Imaging},
  series = {Ultrasound Elastography},
  volume = {94},
  number = {5},
  pages = {503--513},
  issn = {2211-5684},
  doi = {10.1016/j.diii.2013.02.006},
  abstract = {Breast elastography is being increasingly used to better characterize breast lesions. Published studies have shown that it improved specificity of B mode ultrasound. Two elastography modes are available: free-hand elastography and shear wave elastography. Free-hand elastography is obtained by a mechanic wave induced by the ultrasound probe, deforming the target, either by small movements induced by breathe. An elastogram is obtained and displayed either as a colour map or a size ratio or elasticity ratio measurement. The second mode is shear wave elastography; two methods are available: Shear Wave Elastography (SWE) and ARFI mode (Acoustic Radiation Force Impulse). Shear wave elastography is less operator-dependent than free-hand elastography mode and provides a quantitative approach. A value of over 80kPa (SWE) or velocity results of over 2m/s (ARFI) are considered as suspicious. False negatives may occur in soft breast cancers (mucinous carcinoma, carcinoma with an inflammatory stroma, etc.) and false positives may be seen with poorly deformable benign lesions such as old fibrous adenomas. In practical use, elastography is a useful complementary tool for undetermined breast lesions categorized as BI-RADS 4a or BI-RADS 3, or for cystic lesions but cannot avoid fine needle aspiration or core biopsy if ultrasound features are clearly suspicious.},
  keywords = {Characterization,Elastography,Shear Wave elastography,Ultrasound},
  file = {/Users/keita/Zotero/storage/74SNLI3I/S2211568413000417.html}
}

